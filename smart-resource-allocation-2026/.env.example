# Smart Resource Allocation - Single Root Env Template

# App
APP_NAME=Smart Resource Allocation API
APP_ENV=development
API_PREFIX=/api

# Database / Cache
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sra
REDIS_URL=redis://localhost:6379/0

# GCP / Cloud Tasks
GOOGLE_CLOUD_PROJECT=your-gcp-project
GCP_REGION=asia-south1
CLOUD_TASKS_QUEUE=ripple-dispatch
CLOUD_TASKS_WORKER_URL=http://localhost:8081/internal/dispatch/execute
CLOUD_TASKS_SERVICE_ACCOUNT=service-account@your-gcp-project.iam.gserviceaccount.com

# Storage
GCS_BUCKET_VOICE=sra-voice-recordings
GCS_BUCKET_PAPER=sra-paper-uploads

# AI
GROQ_API_KEY=replace-with-groq-api-key
GROQ_WHISPER_MODEL=whisper-large-v3
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro
MATCHING_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Auth / Notifications
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CREDENTIALS_PATH=/secrets/firebase-admin.json
FCM_TOPIC_VOLUNTEERS=volunteer-updates

# Matching + Retention
MAX_RIPPLE_RADIUS_KM=10
RIPPLE_TIMEOUT_SECONDS=60
DATA_RETENTION_DAYS=30

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_MAPTILER_KEY=replace-with-maptiler-key
NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-firebase-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-with-firebase-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=replace-with-firebase-app-id

# Mobile (future use)
API_BASE_URL=http://localhost:8080
MAPTILER_KEY=replace-with-maptiler-key
