APP_NAME=Smart Resource Allocation API
APP_ENV=development
API_PREFIX=/api

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sra
REDIS_URL=redis://localhost:6379/0

GOOGLE_CLOUD_PROJECT=your-gcp-project
GCP_REGION=asia-south1
CLOUD_TASKS_QUEUE=ripple-dispatch
CLOUD_TASKS_WORKER_URL=https://worker-service-url/internal/dispatch/execute
CLOUD_TASKS_SERVICE_ACCOUNT=service-account@project.iam.gserviceaccount.com

GCS_BUCKET_VOICE=sra-voice-recordings
GCS_BUCKET_PAPER=sra-paper-uploads

GROQ_API_KEY=your-groq-key
GROQ_WHISPER_MODEL=whisper-large-v3

GEMINI_API_KEY=your-gemini-key
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro

FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CREDENTIALS_PATH=/secrets/firebase-admin.json
FCM_TOPIC_VOLUNTEERS=volunteer-updates

MATCHING_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MAX_RIPPLE_RADIUS_KM=10
RIPPLE_TIMEOUT_SECONDS=60
DATA_RETENTION_DAYS=30
